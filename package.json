{
  "name": "forms-adaptor-template",
  "version": "0.0.0",
  "description": "forms-adaptor-template",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development npm run server:watch",
    "dev:debug": "NODE_ENV=development npm run server:debug",
    "docker:dev": "npm run dev",
    "build": "npm run type-check",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "type-check": "tsc --noEmit -p jsconfig.json",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\" && npm run type-check",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "npm run setup:husky",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-sqs": "3.1062.0",
    "@defra/forms-engine-plugin": "4.14.3",
    "@defra/forms-model": "3.0.675",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "aws-embedded-metrics": "4.2.1",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "4.1.3",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "joi": "17.13.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.8",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "7.1.0",
    "eslint": "9.29.0",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "vitest": "4.1.8",
    "vitest-fetch-mock": "0.4.5"
  }
}
